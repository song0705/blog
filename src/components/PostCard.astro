---
import { formatDate, getPostSlug, getReadingTime, type Post } from "../lib/posts";
import { withBase } from "../lib/site";

type Props = {
  post: Post;
  variant?: "feature" | "compact";
};

const { post, variant = "compact" } = Astro.props;
const slug = getPostSlug(post);
const href = withBase(`posts/${slug}/`);
---

<article class:list={["post-card", `post-card--${variant}`]}>
  <a class="post-card__image" href={href} aria-label={`阅读：${post.data.title}`}>
    <img src={withBase(post.data.heroImage)} alt={post.data.heroAlt} loading="eager" />
  </a>
  <div class="post-card__body">
    <div class="post-meta">
      <span>{post.data.category}</span>
      <span>{formatDate(post.data.pubDate)}</span>
      <span>{getReadingTime(post.body)}</span>
    </div>
    <h2><a href={href}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <div class="tag-row" aria-label="文章标签">
      {post.data.tags.map((tag) => <a href={withBase(`tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>)}
    </div>
  </div>
</article>
