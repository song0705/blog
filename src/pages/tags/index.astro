---
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPublishedPosts, postsByTag } from "../../lib/posts";
import { withBase } from "../../lib/site";

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="标签" description="按主题标签浏览 Cian 技术博客。">
  <PageHero eyebrow="Tags" title="标签" description="用主题线索横向检索文章。" />
  {tags.length > 0 ? (
    <section class="tag-index" aria-label="标签列表">
      {tags.map((tag) => (
        <a href={withBase(`tags/${encodeURIComponent(tag)}/`)}>
          <span>#{tag}</span>
          <strong>{postsByTag(posts, tag).length}</strong>
        </a>
      ))}
    </section>
  ) : <section class="empty-state empty-state--wide">暂无标签。</section>}
</BaseLayout>
